<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence 
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!-- ===== POSTGRESQL ===== -->
    <persistence-unit name="hibernate-postgresql">
        <description>PostgreSQL Database for POB Delivery</description>
        
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <class>modelo.Produto</class>
        <class>modelo.Cliente</class>
        <class>modelo.Pedido</class>
        
        <properties>
            <!-- Conexão JDBC -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/pob"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            
            <!-- Hibernate Properties -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
        </properties>
    </persistence-unit>

    <!-- ===== MYSQL (Alternativa) ===== -->
    <persistence-unit name="hibernate-mysql">
        <description>MySQL Database for POB Delivery</description>
        
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <class>modelo.Produto</class>
        <class>modelo.Cliente</class>
        <class>modelo.Pedido</class>
        
        <properties>
            <!-- Conexão JDBC -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/pob"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            
            <!-- Hibernate Properties -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
        </properties>
    </persistence-unit>

</persistence>